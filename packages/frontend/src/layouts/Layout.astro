---
import "@/styles/global.css";

import genTitle from "@/utils/titleGen"
const {title = "SQLDev"} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width"/>
    <link rel="icon" type="image/svg+xml" href="/sword.svg"/>
    <meta name="generator" content={Astro.generator}/>
    <title>{title === "SQLDev" ? title: genTitle(title) }</title>
</head>
<body class="dark">
<div id="root">
    <slot/>
</div>
</body>
</html>
