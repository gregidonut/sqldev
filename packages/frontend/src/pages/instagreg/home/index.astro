---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/header/Header.astro";
import Main from "@/components/main/Main.astro";

import PageHeader from "../_components/react/PageHeader";
import PostArea from "./_components/react/PostArea";
import LazyLoadedPostList from "./_components/react/LazyLoadedPostList";
import { Resource } from "sst";
---

<Layout title="instagreg">
    <Header title="instagreg" />
    <Main>
        <PageHeader
            client:idle
            pathname={Astro.url.pathname.split("/").filter(Boolean).at(-1) ??
                "home"}
        />
        <PostArea client:only="react" />
        <LazyLoadedPostList
            client:idle
            realtimeEndpoint={Resource.SQLDevRealtimeSST.endpoint}
            realtimeAuthorizer={Resource.SQLDevRealtimeSST.authorizer}
            appName={Resource.App.name}
            appStage={Resource.App.stage}
        />
    </Main>
</Layout>
