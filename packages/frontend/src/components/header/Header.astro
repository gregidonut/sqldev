---
import {Show, UserButton} from "@clerk/astro/components";
import styles from "./header.module.css";

const {title = "sqldev"} = Astro.props;
---

<header
        class="min-h-9 flex-row-between
        bg-drac-selection px-2 py-1"
>
        <h1 class="text-2xl">
            <a href="/">{title}</a>
        </h1>
        <Show when="signed-in">
            <div class={styles.userButtonContainer}>
                <UserButton/>
            </div>
        </Show>
        <Show when="signed-out">
            <a href="/sign-in">Sign in</a>
        </Show>
</header>
